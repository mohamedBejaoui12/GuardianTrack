<?xml version="1.0" encoding="utf-8"?>
<!--
    Navigation graph — defines all screens and the connections between them.
    NavController reads this file and knows how to navigate between fragments.
    The single Activity just hosts the NavHostFragment; it doesn't manage back stack.
-->
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/dashboardFragment">

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.guardian.track.ui.dashboard.DashboardFragment"
        android:label="Dashboard" />

    <fragment
        android:id="@+id/historyFragment"
        android:name="com.guardian.track.ui.history.HistoryFragment"
        android:label="History" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.guardian.track.ui.settings.SettingsFragment"
        android:label="Settings" />

</navigation>
